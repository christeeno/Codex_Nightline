# GEMINI_API_KEY: Optional key for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# VITE_API_URL: Optional public URL of the deployed PARA AI backend.
# Leave unset for local development: Vite proxies /api to VITE_BACKEND_URL.
# VITE_BACKEND_URL="http://localhost:8000"

# APP_URL: Public URL for PARA AI when required by integrations.
APP_URL="MY_APP_URL"
