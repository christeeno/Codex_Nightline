# Application settings
APP_NAME=PARA AI Backend
APP_VERSION=1.0.0
DEBUG=false
DATABASE_URL=sqlite:///./para.db

# Local storage
UPLOAD_FOLDER=uploads
UPLOAD_PATH=uploads/videos
EVIDENCE_PATH=uploads/evidence
WEIGHTS_FOLDER=weights

# Video processing defaults
TRAFFIC_FPS=5
ROAD_FPS=2
TRAFFIC_CONFIDENCE_THRESHOLD=0.40
TRAFFIC_TRACKING_IOU=0.30

# Bike-Helmet-Detectionv2 integration (the repository remains under vendor/)
BIKE_HELMET_MODEL_PATH=vendor/Bike-Helmet-Detectionv2/weights/best.pt
BIKE_HELMET_DEVICE=cpu
BIKE_HELMET_TRACKER=bytetrack.yaml
BIKE_HELMET_MOTORCYCLE_LABELS=motorcycle,bike,motorbike
BIKE_HELMET_RIDER_LABELS=rider,bike rider,motorcycle rider
BIKE_HELMET_NO_HELMET_LABELS=no helmet,no_helmet,nohelmet,without helmet,without_helmet
MAX_UPLOAD_SIZE_MB=500

# Road intelligence (PeterHdd/pothole-detection-yolo)
# The repository's published pretrained model; set this to a local file path to
# avoid downloading weights at runtime.
MODEL_PATH=https://huggingface.co/peterhdd/pothole-detection-yolov8/resolve/main/best.pt
DEVICE=cpu
POTHOLE_CONFIDENCE=0.55
MIN_CONSECUTIVE_FRAMES=2
POTHOLE_EVENT_IOU=0.15
POTHOLE_EVENT_DISTANCE=0.20
VEHICLE_OVERLAP_THRESHOLD=0.40
ROI_ENABLED=true
ROAD_ROI_TOP_RATIO=0.35
SUPPORTED_FORMATS=mp4,mov,avi

# Operational settings
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

# License plate recognition (PaddleOCR)
OCR_CONFIDENCE=0.80
PLATE_CONFIDENCE=0.40
MIN_PLATE_SIZE=20
MAX_PLATE_SIZE=800
MIN_PLATE_ASPECT_RATIO=1.5
MAX_PLATE_ASPECT_RATIO=7.0
PLATE_BLUR_KERNEL_SIZE=5
PLATE_CANNY_LOWER_THRESHOLD=75
PLATE_CANNY_UPPER_THRESHOLD=200
UNKNOWN_LABEL=UNKNOWN
OCR_USE_ANGLE_CLASSIFICATION=true

# Incident grouping and evidence selection
INCIDENT_DEDUPLICATION_SECONDS=3.0
INCIDENT_NEIGHBOUR_FRAME_WINDOW=5
INCIDENT_DEFAULT_STATUS=pending_review
