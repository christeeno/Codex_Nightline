# Application runtime settings
APP_NAME="Para AI Backend"
ENVIRONMENT="development"
DEBUG=false
LOG_LEVEL="INFO"

# Comma-separated origins permitted to access the API from browsers.
CORS_ORIGINS="http://localhost:5173,http://127.0.0.1:5173"

# SQLite database location. A relative path is resolved from the backend directory.
DATABASE_URL="sqlite:///./data/para_ai.db"
